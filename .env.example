# ─────────────────────────────────────────────────────────────────────────────
# Development (docker-compose.dev.yml) - uses these defaults
# Production  (docker-compose.prod.yml) - override with production values below
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://clawix:clawix_dev@localhost:5433/clawix?schema=public"
# Production (docker-compose.prod.yml): these are interpolated at compose-parse
# time, so they must live in .env (not just env_file). POSTGRES_PASSWORD is
# required — `docker compose -f docker-compose.prod.yml build` fails without it.
# POSTGRES_USER and POSTGRES_DB default to "clawix" if unset.
# POSTGRES_USER=clawix
# POSTGRES_PASSWORD=change-me-strong-secret
# POSTGRES_DB=clawix

# Redis
REDIS_URL="redis://localhost:6379"

# API Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
# Production: NODE_ENV=production, LOG_LEVEL=info

# Web (Next.js) — both vars are baked into the bundle at `next build` time.
# Rebuild the web image (`docker compose -f docker-compose.prod.yml build web`)
# whenever you change them.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# CORS (comma-separated origins allowed to call the API)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production: CORS_ALLOWED_ORIGINS=https://your-domain.com

# Bundled TLS proxy (docker-compose.prod.yml "tls" profile) — OPTIONAL.
# Only needed if you serve a public domain via the built-in nginx-proxy +
# Let's Encrypt instead of an external proxy. Set both, then start with:
#   docker compose -f docker-compose.prod.yml --profile tls up -d
# Left blank, the proxy services stay off and the stack serves over plain HTTP.
# DOMAIN=your-domain.com
# LETSENCRYPT_EMAIL=you@your-domain.com

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Provider Encryption Key (32-byte hex for AES-256-GCM encryption of stored API keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_ENCRYPTION_KEY=$(openssl rand -hex 32)

# Container Isolation
AGENT_CONTAINER_IMAGE=clawix-agent:latest
AGENT_MAX_RETRIES=2
AGENT_TIMEOUT_SECONDS=300
WORKSPACE_BASE_PATH=./data

# When running via docker-compose, the API container mounts ./data at /data.
# Docker daemon resolves -v paths on the host, so we need the host-side path
# for agent workspace mounts. docker-compose files default to ${PWD}/data.
# For production, set the absolute host path:
# CLAWIX_HOST_DATA_DIR=/absolute/host/path/to/data
# CLAWIX_HOST_SKILLS_DIR=/absolute/host/path/to/skills

# Skills
# SKILLS_BUILTIN_DIR=/app/skills/builtin
# SKILLS_BUILTIN_HOST_DIR=/absolute/host/path/to/skills/builtin
# SKILLS_CUSTOM_DIR=/app/skills/custom
# SKILLS_CUSTOM_HOST_DIR=/absolute/host/path/to/data/skills/custom

# Workspace (Not Implemented)
# WORKSPACE_MAX_SIZE_MB=500

# Token Budgets (Not Implemented)
# DEFAULT_MONTHLY_TOKEN_BUDGET_USD=100

# --- Web Search (optional) ---
# Brave Search API key (free tier: 2000 req/month)
# If set, Brave is used as primary search with DuckDuckGo fallback.
# If not set, DuckDuckGo is used (no API key required).
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxx
# BRAVE_SEARCH_MAX_RESULTS=5

##################################################
# Configuration (For Seed — dev only, used by `prisma db seed`)
DEFAULT_PASSWORD=password1234

# DEFAULT_PROVIDER options: anthropic, openai, zai-coding, deepseek, or any custom provider id.
DEFAULT_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

##################################################
# Production bootstrap (consumed by dist/bootstrap.js on first container start).
# Leave empty to skip bootstrap — useful once the admin exists.
# The bootstrap is idempotent: re-runs find the admin and exit without changes.
# INITIAL_ADMIN_EMAIL=admin@your-domain.com
# INITIAL_ADMIN_PASSWORD=set-a-strong-password
# INITIAL_ADMIN_NAME=Administrator

# TELEGRAM_BOT_TOKEN=

# Provider API Keys (set the key for your DEFAULT_PROVIDER at minimum).
# Names are the canonical envKey values from packages/shared/src/providers/provider-registry.ts.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ZAI_CODING_API_KEY=
# DEEPSEEK_API_KEY=

# Custom provider (optional — any OpenAI-compatible Chat Completions endpoint).
# Set ALL of NAME / BASE_URL / API_KEY to enable. NAME is used as the DB key
# and may be referenced by DEFAULT_PROVIDER. (Not Implemented)
# CUSTOM_PROVIDER_NAME=my-llm
# CUSTOM_PROVIDER_DISPLAY_NAME=My Local LLM
# CUSTOM_PROVIDER_BASE_URL=http://localhost:8080/v1
# CUSTOM_PROVIDER_DEFAULT_MODEL=llama-3.1-70b
# CUSTOM_PROVIDER_API_KEY=

# --- DigitalOcean droplet provisioning ---
# Your DO personal access token (read+write). Generate at:
# https://cloud.digitalocean.com/account/api/tokens
# DO_API_TOKEN=dop_v1_...
#
# Set to "true" to allow self-service signup from the landing page.
# Leave unset (or "false") to disable public registration.
# ALLOW_PUBLIC_SIGNUP=true

# --- SMTP (transactional email) ---
# Used for OTP verification, payment links, and droplet-ready notifications.
# If SMTP_USER is not set, emails are only logged (no-send mode).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Clawix <noreply@clawix.aibyml.com>

# --- Browser tools ---
BROWSER_PROVIDER=local
BROWSER_SIDECAR_URL=ws://clawix-browser:3000
# Auto-generated by scripts/install.mjs on first install. If you set this manually,
# use a 32-byte hex secret (e.g. `openssl rand -hex 32`) and ensure the same value
# reaches the clawix-browser sidecar (it reads it as TOKEN).
BROWSER_AUTH_TOKEN=
BROWSER_INTERNAL_ALLOWLIST=
BROWSER_QUEUE_TIMEOUT_MS=30000
BROWSER_NAVIGATE_TIMEOUT_MS=30000
BROWSER_OP_TIMEOUT_MS=10000
BROWSER_SIDECAR_MAX_SESSIONS=25

# --- Browser tools: alternate providers (opt-in) ---
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSER_CDP_URL=

# --- Python tools (clawix-pypi-proxy + sibling python-runner) ---
PYTHON_PROXY_URL=http://clawix-pypi-proxy:3141
# Auto-generated by scripts/install.mjs on first install. If you set this manually,
# use a 32-byte hex secret (e.g. `openssl rand -hex 32`) and ensure the same value
# reaches the clawix-pypi-proxy sidecar.
PYTHON_PROXY_AUTH_TOKEN=
PYTHON_RUNNER_IMAGE=clawix-python-runner:latest
PYTHON_POOL_IDLE_TIMEOUT_SEC=300
PYTHON_POOL_MAX_SIZE=20
PYTHON_NET_NETWORK_NAME=clawix-python-net-egress
# Comma-separated host[:port] entries permitted to bypass the RFC1918 block.
# Example: PYTHON_INTERNAL_ALLOWLIST=admin.internal,grafana.internal:3000
PYTHON_INTERNAL_ALLOWLIST=
# Which Plan-tier allowlist file the clawix-pypi-proxy mounts (prod compose only).
# Values: standard | extended | unrestricted. Defaults to extended.
PYTHON_ALLOWLIST_TIER=extended

